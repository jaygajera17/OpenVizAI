{
  "name": "@openvizai/core",
  "version": "0.1.0",
  "description": "Core chart intelligence engine for OpenVizAI: infers chart type and embedding metadata from prompt + dataset sample.",
  "license": "MIT",
  "author": "Jay Gajera",
  "homepage": "https://github.com/OpenVizAI/OpenVizAI#readme",
  "bugs": {
    "url": "https://github.com/OpenVizAI/OpenVizAI/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenVizAI/OpenVizAI.git",
    "directory": "packages/core"
  },
  "keywords": [
    "openvizai",
    "ai",
    "charts",
    "visualization",
    "apexcharts",
    "llm",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build && npm run test",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "zod": "^3.0.0",
    "@openvizai/shared-types": "^0.1.0"
  },
  "peerDependencies": {
    "@langchain/openai": "^1.0.0",
    "@langchain/core": "^1.0.0",
    "@langchain/google-genai":  "^2.1.24"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^3.2.3"
  }
}
