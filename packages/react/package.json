{
  "name": "@openvizai/react",
  "version": "0.1.2",
  "description": "React renderer components for OpenVizAI chart metadata powered by ApexCharts.",
  "license": "MIT",
  "author": "Jay Gajera",
  "homepage": "https://github.com/OpenVizAI/OpenVizAI#readme",
  "bugs": {
    "url": "https://github.com/OpenVizAI/OpenVizAI/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenVizAI/OpenVizAI.git",
    "directory": "packages/react"
  },
  "keywords": [
    "openvizai",
    "react",
    "charts",
    "visualization",
    "apexcharts",
    "dashboard",
    "typescript",
    "gen-ai-charts",
    "generative-charts"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@openvizai/shared-types": "^0.1.1"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "apexcharts": ">=5.0.0",
    "react-apexcharts": ">=2.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "apexcharts": "^5.6.0",
    "react-apexcharts": "^2.0.1"
  }
}
