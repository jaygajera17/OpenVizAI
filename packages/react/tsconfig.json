{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": "src",
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "module": "ES2020",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "@openvizai/*": ["packages/*/dist"],
      "@openvizai/shared-types": ["packages/shared-types/dist/index.d.ts"]
    }
  },
  "include": ["src"]
}
