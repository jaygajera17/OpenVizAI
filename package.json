{
  "name": "OpenVizAI",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:server": "cd apps/server && npm run dev",
    "dev:web": "cd apps/web && npm run dev",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "bootstrap": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "apexcharts": "^5.6.0",
    "react-apexcharts": "^2.0.1",
    "react-router-dom": "^7.13.0"
  }
}
